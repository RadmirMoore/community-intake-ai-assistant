# ---------------------------------------------------------------------------
# Community Intake Assistant — environment variables
# Copy this file to `.env.local` and fill in the values you need.
# The app runs with ZERO configuration (local JSON store + rule-based triage),
# so every variable below is optional — but set them for a real deployment.
# ---------------------------------------------------------------------------

# Anthropic API — enables real AI triage (classification, summary, follow-up).
# Without this, the app falls back to a transparent rule-based triage.
ANTHROPIC_API_KEY=

# Optional: override the Claude model used for triage.
# Defaults to "claude-sonnet-5".
ANTHROPIC_MODEL=claude-sonnet-5

# Staff dashboard password. When unset, the dashboard is OPEN (demo mode only).
# REQUIRED for any real deployment — intake data is sensitive.
DASHBOARD_PASSWORD=

# Supabase — enables persistent Postgres storage.
# Without these, the app stores submissions in a local JSON file (.data/).
# The service role key is used server-side only and must never be exposed
# to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis — enables a shared rate limiter for serverless/multi-instance
# deployments. Without these, rate limiting falls back to an in-memory map
# (fine for a single server or a demo, not coordinated across instances).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
